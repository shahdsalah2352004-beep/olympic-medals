pleted_at": "2026-04-06T12:04:25.269360Z"}, {"name": "execute", "started_at": "2026-04-06T12:04:25.285361Z", "completed_at": "2026-04-06T12:04:28.899294Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 4.075409650802612, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c386f6-0003-1aac-0003-519600025022"}, "message": "SUCCESS 1", "failures": null, "unique_id": "model.olympic_medals.dim_athlete", "compiled": true, "compiled_code": "\n\nSELECT\n    ROW_NUMBER() OVER (ORDER BY athlete_name) AS athlete_id,\n    athlete_name AS full_name,\n    country_code\nFROM (SELECT DISTINCT athlete_name, country_code FROM OLYMPIC_MEDALS.PUBLIC_PUBLIC.stg_medals WHERE athlete_name IS NOT NULL) a", "relation_name": "OLYMPIC_MEDALS.PUBLIC_PUBLIC.dim_athlete"}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T12:04:29.223320Z", "completed_at": "2026-04-06T12:04:29.266539Z"}, {"name": "execute", "started_at": "2026-04-06T12:04:29.273076Z", "completed_at": "2026-04-06T12:04:31.888152Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 2.9218504428863525, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c386f6-0003-1c2b-0003-51960002601e"}, "message": "SUCCESS 1", "failures": null, "unique_id": "model.olympic_medals.dim_event", "compiled": true, "compiled_code": "\n\nSELECT\n    ROW_NUMBER() OVER (ORDER BY e.sport, e.event_name, e.gender) AS event_id,\n    s.sport_id,\n    e.event_name,\n    e.gender\nFROM (SELECT DISTINCT sport, event_name, gender FROM OLYMPIC_MEDALS.PUBLIC_PUBLIC.stg_medals WHERE event_name IS NOT NULL) e\nJOIN OLYMPIC_MEDALS.PUBLIC_PUBLIC.dim_sport s ON e.sport = s.sport_name", "relation_name": "OLYMPIC_MEDALS.PUBLIC_PUBLIC.dim_event"}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T12:04:32.162511Z", "completed_at": "2026-04-06T12:04:32.195098Z"}, {"name": "execute", "started_at": "2026-04-06T12:04:32.205009Z", "completed_at": "2026-04-06T12:04:34.354789Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 2.455967426300049, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c386f6-0003-1aac-0003-519600025026"}, "message": "SUCCESS 1", "failures": null, "unique_id": "model.olympic_medals.fact_medals", "compiled": true, "compiled_code": "\n\nSELECT\n    ROW_NUMBER() OVER (ORDER BY m.athlete_name, m.year, m.medal_type) AS medal_id,\n    a.athlete_id,\n    m.country_code,\n    s.sport_id,\n    e.event_id,\n    g.games_id,\n    m.medal_type\nFROM OLYMPIC_MEDALS.PUBLIC_PUBLIC.stg_medals m\nJOIN OLYMPIC_MEDALS.PUBLIC_PUBLIC.dim_athlete a ON m.athlete_name = a.full_name AND m.country_code = a.country_code\nJOIN OLYMPIC_MEDALS.PUBLIC_PUBLIC.dim_sport s ON m.sport = s.sport_name\nJOIN OLYMPIC_MEDALS.PUBLIC_PUBLIC.dim_event e ON m.event_name = e.event_name AND m.gender = e.gender\nJOIN OLYMPIC_MEDALS.PUBLIC_PUBLIC.dim_games g ON m.year = g.year AND m.season = g.season", "relation_name": "OLYMPIC_MEDALS.PUBLIC_PUBLIC.fact_medals"}], "elapsed_time": 17.25755286216736, "args": {"enable_legacy_logger": false, "log_path": "D:\\DEPI\\medalists_project\\dbt\\logs", "log_level": "info", "vars": {}, "partial_parse_file_diff": true, "printer_width": 80, "version_check": true, "which": "run", "partial_parse": true, "defer": false, "cache_selected_only": false, "quiet": false, "use_colors": true, "favor_state": false, "macro_debugging": false, "log_file_max_bytes": 10485760, "log_level_file": "debug", "select": [], "indirect_selection": "eager", "static_parser": true, "warn_error_options": {"include": [], "exclude": []}, "invocation_command": "dbt run --profiles-dir .", "use_colors_file": true, "write_json": true, "send_anonymous_usage_stats": true, "exclude": [], "strict_mode": false, "project_dir": "D:\\DEPI\\medalists_project\\dbt", "profiles_dir": ".", "introspect": true, "log_format": "default", "log_format_file": "debug